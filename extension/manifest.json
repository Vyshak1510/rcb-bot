{
  "manifest_version": 3,
  "name": "RCB Ticket Bot",
  "version": "1.0.0",
  "description": "Monitors RCB ticket page and auto-buys when tickets go live",
  "permissions": [
    "alarms",
    "notifications",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "https://shop.royalchallengers.com/*",
    "https://*.ticketgenie.in/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://shop.royalchallengers.com/ticket*",
        "https://*.ticketgenie.in/ticket*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
